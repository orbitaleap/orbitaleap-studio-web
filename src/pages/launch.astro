---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

const singleServices = [
  { name: 'Logotipo', desc: 'Logo vectorial en todos los formatos + paleta de colores.', priceSplit: '290€', priceUpfront: '230€', discount: '−20%' },
  { name: 'Identidad de Marca Completa', desc: 'Logo, tipografías, guía de colores, versiones para redes y manual básico.', priceSplit: '690€', priceUpfront: '550€', discount: '−20%' },
  { name: 'Web de 4-5 Secciones', desc: 'Página única, rápida y adaptada a móvil, con formulario de contacto.', priceSplit: '550€', priceUpfront: '440€', discount: '−20%' }
];

const combinedPacks = [
  { name: 'Pack Emprendedor', sub: 'Diseño de Logotipo y Desarrollo Web', desc: 'Todo lo necesario para arrancar con una imagen profesional desde el primer día.', priceSplit: '790€', priceUpfront: '630€', discount: '−20%', featured: false },
  { name: 'Pack Marca & Web Pro', sub: 'Branding + Web Multipágina', desc: 'Identidad de marca completa y sitio web profesional con SEO inicial incluido.', priceSplit: '1.800€', priceUpfront: '1.350€', discount: '−25%', featured: true },
  { name: 'Pack Plataforma / Tienda', sub: 'Marca + Ecommerce o App', desc: 'Diseño de marca y plataforma web con pasarela de pago o aplicación a medida.', priceSplit: '3.200€', priceUpfront: '2.240€', discount: '−30%', featured: false }
];

const monthlyPlans = [
  { name: 'Mantenimiento & Hosting', price: '49€', unit: '/ mes', annualFull: '588€', annual: '390€ / año', discount: '−20%', detail: 'Hosting, copias de seguridad y 1h/mes de cambios menores.' },
  { name: 'Partner Estudio', price: '690€', unit: '/ mes', annualFull: '8.280€', annual: '6.200€ / año', discount: '−25%', detail: 'Soporte web, hasta 2 landings al mes, 8 piezas de diseño y SEO actualizado cada mes.' },
  { name: 'Full Partner & Redes', price: '1.950€', unit: '/ mes', annualFull: '23.400€', annual: '16.380€ / año', discount: '−30%', detail: 'Gestión de redes sociales, SEO actualizado cada mes y hasta 8 tareas de diseño y desarrollo (tamaño pequeño o mediano) al mes, 1 activa a la vez.' }
];
---

<Layout
  title="Diseño y Desarrollo de Webs y Apps | Orbital Leap Studio"
  description="Creamos la página web o app que necesita tu empresa. Respuesta en menos de 24 horas."
  noindex
>
  <main class="bg-[#0A0A0A] text-black overflow-x-hidden">

    <style>
      /* ── Type ── */
      .display    { font-size: clamp(2.4rem, 7vw, 5.5rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.04; }
      .display-sm { font-size: clamp(1.75rem, 4.5vw, 3rem); font-weight: 700; letter-spacing: -0.025em; line-height: 1.08; }
      .label-caps { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }

      /* ── Buttons ── */
      .btn-black   { display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;background:#000;color:#fff;border:1.5px solid #000;border-radius:9999px;padding:0.8rem 1.75rem;font-family:inherit;font-size:0.8125rem;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;cursor:pointer;transition:background 0.18s,border-color 0.18s; }
      .btn-black:hover { background:#222;border-color:#222; }
      .btn-outline { display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;background:transparent;color:#000;border:1.5px solid rgba(0,0,0,0.22);border-radius:9999px;padding:0.8rem 1.75rem;font-family:inherit;font-size:0.8125rem;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;cursor:pointer;transition:border-color 0.18s,background 0.18s; }
      .btn-outline:hover { border-color:rgba(0,0,0,0.45);background:rgba(0,0,0,0.03); }
      .btn-white   { display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;background:#fff;color:#000;border:1.5px solid #fff;border-radius:9999px;padding:0.8rem 1.75rem;font-family:inherit;font-size:0.8125rem;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;cursor:pointer;transition:background 0.18s,border-color 0.18s; }
      .btn-white:hover  { background:#e8e8e8;border-color:#e8e8e8; }
      .btn-outline-w { display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,0.25);border-radius:9999px;padding:0.8rem 1.75rem;font-family:inherit;font-size:0.8125rem;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;cursor:pointer;transition:border-color 0.18s,background 0.18s; }
      .btn-outline-w:hover { border-color:rgba(255,255,255,0.5);background:rgba(255,255,255,0.06); }

      /* ── Card CTA: plain text link, no button box — a boxed CTA on every
         single card read as generic "SaaS pricing template" ── */
      .card-link-btn { background:none;border:none;padding:0;font-family:inherit;font-size:1.0625rem;font-weight:700;color:#fff;letter-spacing:0.01em;transition:color 0.18s; }
      .card-link-btn:hover { color:rgba(255,255,255,0.7); }

      /* ── Fields ── */
      .field { width:100%;padding:0.875rem 1rem;border-radius:12px;border:1.5px solid rgba(0,0,0,0.11);background:#fff;font-family:inherit;font-size:0.875rem;color:#000;transition:border-color 0.18s,box-shadow 0.18s; }
      .field::placeholder { color:rgba(0,0,0,0.28); }
      .field:focus { outline:none;border-color:#000;box-shadow:0 0 0 3px rgba(0,0,0,0.05); }

      /* ── Section stacking — rounded top cards ──
         Radius scales with viewport: 72px reads huge on a narrow phone
         (nearly 20% of the screen width), so it's smaller by default and
         only goes big at md+ where there's room for it. */
      .stack-card {
        position: relative;
        border-radius: 36px 36px 0 0;
        margin-top: -36px;
        z-index: 1;
      }
      @media (min-width: 768px) {
        .stack-card {
          border-radius: 72px 72px 0 0;
          margin-top: -72px;
        }
      }
      .stack-card + .stack-card { z-index: 2; }
      .stack-card + .stack-card + .stack-card { z-index: 3; }

      /* ── Pricing rows (dark section) ── */
      .pricing-row { border-bottom:1px solid rgba(255,255,255,0.08);transition:background 0.15s; }
      .pricing-row:hover { background:rgba(255,255,255,0.02); }
      .pricing-row:last-child { border-bottom:none; }

      /* ── Pack cards (dark section) ── */
      .pack-card { position:relative;border:1.5px solid rgba(255,255,255,0.1);border-radius:28px;background:rgba(255,255,255,0.03);transition:border-color 0.18s,background 0.18s;overflow:hidden; }
      .pack-card:hover { border-color:rgba(255,255,255,0.24);background:rgba(255,255,255,0.05); }
      .pack-card-featured { border:1.5px solid rgba(255,255,255,0.18);background:rgba(255,255,255,0.05); }

      /* ── Test card ── */
      .test-card { border:1.5px solid rgba(0,0,0,0.1);border-radius:28px;background:#fff;transition:border-color 0.18s; }
      .test-card:hover { border-color:rgba(0,0,0,0.28); }

      /* ── Form card ── */
      .form-card  { border:1.5px solid rgba(0,0,0,0.09);border-radius:28px;background:#fff;overflow:hidden; }

      /* ── Discount badge: monochrome outline, no filled colour ── */
      .discount-badge { display:inline-flex;align-items:center;gap:0.3em;background:transparent;color:rgba(255,255,255,0.85);border:1px solid rgba(255,255,255,0.3);border-radius:9999px;padding:0.2rem 0.65rem; }

      /* ── Billing toggle: 2 Plazos / Pago único — drives every price below ── */
      .billing-toggle-btn { font-family:inherit;font-size:0.8125rem;font-weight:600;letter-spacing:0.02em;color:rgba(255,255,255,0.55);background:transparent;border:none;border-radius:9999px;padding:0.6rem 1.25rem;cursor:pointer;display:inline-flex;align-items:center;transition:background 0.18s,color 0.18s; }
      .billing-toggle-btn:hover { color:rgba(255,255,255,0.85); }
      .billing-toggle-btn.active { background:#fff;color:#000; }
      .billing-toggle-btn.active:hover { color:#000; }
      /* the white-on-transparent badge disappears on the toggle's white
         active state — swap to a dark-outline variant there */
      .billing-toggle-btn.active .discount-badge { color:rgba(0,0,0,0.7);border-color:rgba(0,0,0,0.3); }

      /* ── Price visibility: exactly one of these shows per row, driven by #pricing-content[data-billing] ── */
      #pricing-content[data-billing="split"] .price-full { display:none; }
      #pricing-content[data-billing="full"] .price-split { display:none; }

      /* ── Section numeral badge (dark section) ── */
      .sec-num { width:2.5rem;height:2.5rem;border-radius:9999px;border:1px solid rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;font-family:inherit;font-size:0.9375rem;font-weight:700;color:rgba(255,255,255,0.7);flex-shrink:0; }

      /* ── Border beam: animated gradient outline for the recommended pack ── */
      .border-beam-wrapper { position:absolute;inset:0;overflow:hidden;border-radius:inherit;pointer-events:none; }

      /* ── Parallax hero content ── */
      #hero-parallax { will-change: transform; }

      /* ── Header contrast: flipped by scroll-position JS ── */
      .header-light #header-nav-link { color: rgba(0,0,0,0.45); }
      .header-light #header-nav-link:hover { color: #000; }
      .header-dark #header-nav-link { color: rgba(255,255,255,0.5); }
      .header-dark #header-nav-link:hover { color: #fff; }
      .header-light { border-bottom-color: rgba(0,0,0,0.06); }
      .header-dark { border-bottom-color: rgba(255,255,255,0.1); }
    </style>

    <!-- ═══ FIXED HEADER — minimal-tint glass; logo/link/button contrast is
         flipped by scroll-position JS below (light hero/CTA vs dark pricing/footer) ═══ -->
    <header id="site-header" class="header-light fixed top-0 left-0 w-full z-50 px-6 md:px-12 py-4 bg-white/[0.04] backdrop-blur-xl border-b border-white/10 transition-[border-color] duration-300">
      <nav class="flex justify-between items-center max-w-screen-xl mx-auto">
        <a href="/"><img id="header-logo" src="/brand/ol_imagotipo-hk.svg" alt="Orbital Leap" class="h-7 w-auto" /></a>
        <div class="flex items-center gap-3">
          <a href="/test-autodiagnostico" id="header-nav-link" class="hidden sm:block label-caps px-3 py-2 transition-colors">Test Gratuito</a>
          <button type="button" id="header-cta" data-open-contact class="btn-black">Escríbenos</button>
        </div>
      </nav>
    </header>

    <!-- ═══════════════════════════════════════
         HERO — OFF-WHITE
    ═══════════════════════════════════════ -->
    <section id="hero-section" class="relative bg-[#F7F7F5] pt-32 pb-40 md:pt-44 md:pb-56 px-6 md:px-12 xl:px-20 overflow-hidden">

      <!-- Parallax content wrapper -->
      <div id="hero-parallax" class="max-w-screen-xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

        <!-- Left -->
        <div class="lg:col-span-7 flex flex-col pt-2">
          <h1 class="display text-black mb-8">
            Creamos la web o app que necesita tu negocio.
          </h1>

          <p class="font-sans text-black/55 text-lg font-light leading-relaxed max-w-lg mb-10">
            Diseño, programación y puesta en marcha. Hablamos contigo directamente y te explicamos cada paso sin tecnicismos.
          </p>

          <div class="flex flex-wrap gap-3 mb-14">
            <a href="/test-autodiagnostico" class="btn-black">
              <Icon name="ph:target-bold" class="w-4 h-4" />
              Test Gratuito (2 min)
            </a>
            <button type="button" data-open-contact class="btn-outline">Pedir Presupuesto</button>
          </div>

          <div class="flex gap-10 pt-10 border-t border-black/[0.08]">
            <div>
              <span class="font-sans text-3xl font-bold text-black block">&lt;24h</span>
              <span class="label-caps text-black/35 mt-1 block">Respuesta</span>
            </div>
            <div>
              <span class="font-sans text-3xl font-bold text-black block">100%</span>
              <span class="label-caps text-black/35 mt-1 block">Código tuyo</span>
            </div>
            <div>
              <span class="font-sans text-3xl font-bold text-black block">Hasta −30%</span>
              <span class="label-caps text-black/35 mt-1 block">Al pagar hoy</span>
            </div>
          </div>
        </div>

        <!-- Right: form (always open) + smaller test invite below -->
        <div class="lg:col-span-5 flex flex-col gap-4 lg:pt-4">

          <!-- Form -->
          <div class="form-card">
            <div class="px-6 pt-5 pb-1">
              <span class="font-sans text-base font-bold text-black tracking-tight">Cuéntanos qué necesitas</span>
              <p class="font-sans text-xs text-black/40 font-light mt-0.5">Presupuesto en &lt;24 horas, todos los días de la semana. Sin compromiso.</p>
            </div>
            <form id="hero-contact-form" class="flex flex-col gap-4 px-6 pb-6 pt-5">
              <div class="hidden" aria-hidden="true">
                <input type="text" name="website_url" tabindex="-1" autocomplete="off" />
              </div>
              <div>
                <label class="label-caps text-black/40 block mb-1.5">Tu nombre</label>
                <input type="text" name="name" required placeholder="Ej. María García" class="field" />
              </div>
              <div>
                <label class="label-caps text-black/40 block mb-1.5">Correo electrónico</label>
                <input type="email" name="email" required placeholder="hola@empresa.com" class="field" />
              </div>
              <div>
                <label class="label-caps text-black/40 block mb-1.5">Teléfono</label>
                <input type="tel" name="phone" required placeholder="600 000 000" class="field" />
              </div>
              <div>
                <label class="label-caps text-black/40 block mb-1.5">¿Qué tienes en mente?</label>
                <textarea name="message" rows="3" required placeholder="Cuéntanos brevemente tu proyecto o qué quieres mejorar." class="field resize-none"></textarea>
              </div>
              <div class="flex items-start gap-3">
                <input type="checkbox" id="landing-consent" name="consent" required class="mt-0.5 w-4 h-4 shrink-0 rounded border-black/20 accent-black cursor-pointer" />
                <label for="landing-consent" class="font-sans text-xs text-black/50 font-light leading-relaxed cursor-pointer select-none">
                  Acepto el tratamiento de mis datos según la <a href="/privacidad" class="text-black underline underline-offset-2 hover:text-black/70">Política de Privacidad</a> de Orbital Leap.
                </label>
              </div>
              <button type="submit" id="hero-submit-btn" class="btn-black w-full">
                <span id="hero-submit-label" class="inline-flex items-center gap-2">Enviar Consulta →</span>
                <canvas id="hero-submit-orb" class="hidden" width="18" height="18" aria-hidden="true"></canvas>
              </button>
              <p id="hero-status-msg" class="text-xs text-center font-sans hidden"></p>
            </form>
          </div>

          <!-- Smaller test invite -->
          <a href="/test-autodiagnostico" class="test-card flex items-center gap-3 px-5 py-4 no-underline group">
            <span class="w-8 h-8 rounded-full border border-black/10 flex items-center justify-center shrink-0 text-black/70">
              <Icon name="ph:target" class="w-3.5 h-3.5" />
            </span>
            <span class="flex-1 font-sans text-sm text-black/60 font-light leading-snug">
              <strong class="font-semibold text-black">¿No sabes por dónde empezar?</strong> Responde 6 preguntas en 2 minutos y te decimos qué necesitas.
            </span>
            <span class="font-sans text-sm font-bold text-black shrink-0">→</span>
          </a>

        </div>
      </div>

    </section>

    <!-- ═══════════════════════════════════════
         PRICING — DARK CARD (stacked over hero)
    ═══════════════════════════════════════ -->
    <section data-header-dark-zone class="stack-card bg-[#0A0A0A] py-20 md:py-28 px-6 md:px-12 xl:px-20">
      <div id="pricing-content" data-billing="split" class="max-w-screen-xl mx-auto">

        <div class="mb-10">
          <h2 class="display-sm text-white">Un precio.<br />Sin letra pequeña.</h2>
        </div>

        <!-- Billing toggle — controls every price below -->
        <div id="billing-toggle" class="inline-flex items-center gap-1 p-1 rounded-full border border-white/15 bg-white/5 mb-3" role="tablist" aria-label="Forma de pago">
          <button type="button" data-billing-option="split" role="tab" aria-selected="true" class="billing-toggle-btn active">2 Plazos</button>
          <button type="button" data-billing-option="full" role="tab" aria-selected="false" class="billing-toggle-btn">
            Pago único <span class="discount-badge label-caps ml-1">Ahorra hasta 30%</span>
          </button>
        </div>
        <p class="label-caps text-white/35 mb-12 md:mb-16">Precios sin IVA. Se añade el 21% en el presupuesto final.</p>

        <!-- 01 -->
        <div class="mb-12 md:mb-16">
          <div class="flex items-center gap-4 mb-8 pb-5 border-b border-white/[0.08]">
            <span class="sec-num" aria-hidden="true">01</span>
            <div>
              <h3 class="font-sans text-xl font-bold text-white tracking-tight">Servicios individuales</h3>
              <p class="font-sans text-base text-white/65 font-light">Empieza solo con lo que necesitas ahora mismo.</p>
            </div>
          </div>
          <div>
            {singleServices.map((s) => (
              <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-6 px-2">
                <div>
                  <h4 class="font-sans text-base font-bold text-white tracking-tight">{s.name}</h4>
                  <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-sm">{s.desc}</p>
                </div>
                <div class="text-right shrink-0">
                  <span class="price-split">
                    <span class="label-caps text-white/45 block mb-1">2 plazos</span>
                    <span class="font-sans text-2xl font-bold text-white">{s.priceSplit}</span>
                  </span>
                  <span class="price-full">
                    <span class="discount-badge label-caps mb-1">{s.discount} pago único</span>
                    <span class="flex items-baseline justify-end gap-2">
                      <span class="font-sans text-base text-white/35 line-through">{s.priceSplit}</span>
                      <span class="font-sans text-2xl font-bold text-white">{s.priceUpfront}</span>
                    </span>
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- 02 -->
        <div class="mb-12 md:mb-16">
          <div class="flex items-center gap-4 mb-8 pb-5 border-b border-white/[0.08]">
            <span class="sec-num" aria-hidden="true">02</span>
            <div>
              <h3 class="font-sans text-xl font-bold text-white tracking-tight">Complementos</h3>
              <p class="font-sans text-base text-white/65 font-light">Horas sueltas y asesoramiento cuando lo necesites, sin atarte a un plan.</p>
            </div>
          </div>
          <div>
            <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-6 px-2">
              <div>
                <h4 class="font-sans text-base font-bold text-white tracking-tight">Horas de Desarrollo</h4>
                <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-sm">Bloques de horas sueltas para cambios, mejoras o soporte puntual fuera de un plan mensual.</p>
              </div>
              <div class="text-right shrink-0">
                <span class="font-sans text-2xl font-bold text-white">45€</span>
                <span class="label-caps text-white/50 block">/ hora</span>
              </div>
            </div>
            <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-6 px-2">
              <div>
                <h4 class="font-sans text-base font-bold text-white tracking-tight">Redacción de Contenidos</h4>
                <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-sm">Textos escritos a medida para cada página, pensados para captar clientes.</p>
              </div>
              <div class="text-right shrink-0">
                <span class="font-sans text-2xl font-bold text-white">60€</span>
                <span class="label-caps text-white/50 block">/ página</span>
              </div>
            </div>
            <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-6 px-2">
              <div>
                <h4 class="font-sans text-base font-bold text-white tracking-tight">Auditoría SEO</h4>
                <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-sm">Informe con los cambios concretos para mejorar tu posicionamiento en buscadores.</p>
              </div>
              <div class="text-right shrink-0">
                <span class="font-sans text-2xl font-bold text-white">150€</span>
              </div>
            </div>
            <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-6 px-2">
              <div>
                <h4 class="font-sans text-base font-bold text-white tracking-tight">SEO para tu Web</h4>
                <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-sm">Optimizamos tu web actual para buscadores: metadatos, velocidad y estructura. ¿Quieres que se mantenga actualizado cada mes? Está incluido en Partner Estudio y Full Partner & Redes.</p>
              </div>
              <div class="text-right shrink-0">
                <span class="font-sans text-2xl font-bold text-white">300€</span>
              </div>
            </div>
            <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-6 px-2">
              <div>
                <h4 class="font-sans text-base font-bold text-white tracking-tight">Migración de Web Existente</h4>
                <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-sm">Trasladamos tu contenido y dominio actual a la nueva web sin perder nada por el camino.</p>
              </div>
              <div class="text-right shrink-0">
                <span class="font-sans text-2xl font-bold text-white">200€</span>
              </div>
            </div>
            <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-6 px-2">
              <div>
                <h4 class="font-sans text-base font-bold text-white tracking-tight">Gestión de Redes Sociales</h4>
                <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-sm">Publicaciones y calendario de contenido para tus redes, sin comprometerte a un plan completo.</p>
              </div>
              <div class="text-right shrink-0">
                <span class="font-sans text-2xl font-bold text-white">250€</span>
                <span class="label-caps text-white/50 block">/ mes</span>
              </div>
            </div>
            <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-6 px-2">
              <div>
                <h4 class="font-sans text-base font-bold text-white tracking-tight">Consultoría Estratégica</h4>
                <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-sm">Sesión de asesoramiento a medida sobre tu proyecto, estrategia digital o stack tecnológico.</p>
              </div>
              <div class="shrink-0">
                <button type="button" data-open-contact class="btn-outline-w cursor-pointer">Pedir Presupuesto →</button>
              </div>
            </div>
            <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-6 px-2">
              <div>
                <h4 class="font-sans text-base font-bold text-white tracking-tight">Consultoría IA</h4>
                <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-sm">Asesoramiento sobre cómo integrar inteligencia artificial en tu negocio: automatización, atención al cliente o flujos de trabajo.</p>
              </div>
              <div class="shrink-0">
                <button type="button" data-open-contact class="btn-outline-w cursor-pointer">Pedir Presupuesto →</button>
              </div>
            </div>
          </div>
        </div>

        <!-- 03 -->
        <div class="mb-12 md:mb-16">
          <div class="flex items-center gap-4 mb-8 pb-5 border-b border-white/[0.08]">
            <span class="sec-num" aria-hidden="true">03</span>
            <div>
              <h3 class="font-sans text-xl font-bold text-white tracking-tight">Servicios mensuales</h3>
              <p class="font-sans text-base text-white/65 font-light">Tu equipo de diseño y desarrollo de confianza, mes a mes.</p>
            </div>
          </div>
          <div>
            {monthlyPlans.map((plan) => (
              <div class="pricing-row flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-7 px-2">
                <div>
                  <h4 class="font-sans text-base font-bold text-white tracking-tight">{plan.name}</h4>
                  <p class="font-sans text-base text-white/65 font-light mt-0.5 max-w-md">{plan.detail}</p>
                </div>
                <div class="text-right shrink-0">
                  <span class="price-split">
                    <span class="font-sans text-2xl font-bold text-white">{plan.price}</span>
                    <span class="label-caps text-white/50 block">{plan.unit}</span>
                  </span>
                  <span class="price-full">
                    <span class="discount-badge label-caps mb-1">{plan.discount} pago único</span>
                    <span class="flex items-baseline justify-end gap-2">
                      <span class="font-sans text-base text-white/35 line-through">{plan.annualFull}</span>
                      <span class="font-sans text-xl font-bold text-white">{plan.annual}</span>
                    </span>
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- 04 -->
        <div>
          <div class="flex items-center gap-4 mb-8 pb-5 border-b border-white/[0.08]">
            <span class="sec-num" aria-hidden="true">04</span>
            <div>
              <h3 class="font-sans text-xl font-bold text-white tracking-tight">Packs todo incluido</h3>
              <p class="font-sans text-base text-white/65 font-light">Marca y web en un proyecto. Más cohesión, más ahorro.</p>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {combinedPacks.map((pack) => (
              <div class={`relative p-7 flex flex-col justify-between ${pack.featured ? 'pack-card pack-card-featured' : 'pack-card'}`}>
                {pack.featured && (
                  <div class="border-beam-wrapper">
                    <svg class="w-full h-full" fill="none">
                      <rect width="100%" height="100%" rx="28" pathLength="1000" stroke="url(#pack-featured-gradient)" stroke-width="2.5" class="magic-border-beam-svg" />
                      <defs>
                        <linearGradient id="pack-featured-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                          <stop offset="0%" stop-color="#ffffff" stop-opacity="1" />
                          <stop offset="40%" stop-color="#2dd4bf" stop-opacity="0.9" />
                          <stop offset="70%" stop-color="#3b82f6" stop-opacity="0.7" />
                          <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
                        </linearGradient>
                      </defs>
                    </svg>
                  </div>
                )}
                <div class="relative">
                  <span class="label-caps text-white/55 block mb-2">{pack.sub}</span>
                  <h4 class="font-sans text-lg font-bold text-white tracking-tight mb-2">{pack.name}</h4>
                  <p class="font-sans text-base text-white/70 font-light leading-relaxed">{pack.desc}</p>
