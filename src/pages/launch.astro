                <div class="relative mt-6 pt-5 border-t border-white/[0.08]">
                  <span class="price-split block mb-5">
                    <span class="label-caps text-white/50 block mb-1">2 plazos</span>
                    <span class="font-sans text-3xl font-bold text-white">{pack.priceSplit}</span>
                  </span>
                  <span class="price-full block mb-5">
                    <span class="discount-badge label-caps mb-1">{pack.discount} pago único</span>
                    <span class="flex items-baseline gap-2">
                      <span class="font-sans text-base text-white/35 line-through">{pack.priceSplit}</span>
                      <span class="font-sans text-3xl font-bold text-white">{pack.priceUpfront}</span>
                    </span>
                  </span>
                  <div class="pt-4 text-right">
                    <button type="button" data-open-contact class="card-link-btn cursor-pointer">
                      Contratar →
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════
         CLOSING CTA — DARK CARD (stacked over pricing)
    ═══════════════════════════════════════ -->
    <section class="stack-card bg-[#F7F7F5] pt-20 md:pt-28 pb-20 md:pb-28 px-6 md:px-12 xl:px-20">
      <div class="max-w-screen-xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-10">
        <div>
          <span class="label-caps text-black/40 block mb-4">Orbital Leap Studio</span>
          <h2 class="display-sm text-black max-w-xl">¿Listo para empezar?</h2>
          <p class="font-sans text-black/60 text-lg font-light mt-4 max-w-md leading-relaxed">
            Escríbenos hoy y te enviamos un presupuesto concreto. Todos los días de la semana, sin reuniones innecesarias.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <button type="button" data-open-contact class="btn-black">Hablar con el Estudio →</button>
          <a href="/test-autodiagnostico" class="btn-outline">Test Gratuito</a>
        </div>
      </div>
    </section>

    <!-- Footer is its own full-bleed band, not nested inside the CTA
         section's padded container, so its dark background spans edge-to-edge -->
    <Footer compact />

    <ContactModal />
  </main>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { mountOrb } from '../lib/thinking-orb';

  gsap.registerPlugin(ScrollTrigger);

  // ── Parallax between hero and the pricing section sliding over it ──
  // As the dark pricing card scrolls up to cover the hero (via its negative
  // margin), the hero content drifts up and recedes slightly instead of
  // sitting static — the card reads as passing in front of it, not just
  // stacked on top.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    gsap.to('#hero-parallax', {
      y: -70,
      scale: 0.97,
      opacity: 0.85,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero-section',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
    });
  }

  // ── Header contrast: the header sits over both light (hero, closing CTA)
  // and dark (pricing, footer) sections as the page scrolls. Rather than a
  // fixed color that only works against one, flip logo/link/button whenever
  // a dark section is passing directly under the header.
  const header = document.getElementById('site-header') as HTMLElement;
  const headerLogo = document.getElementById('header-logo') as HTMLImageElement;
  const headerCta = document.getElementById('header-cta') as HTMLElement;
  const darkZones = [
    ...document.querySelectorAll('[data-header-dark-zone]'),
    document.getElementById('contacto'),
  ].filter(Boolean) as HTMLElement[];

  function updateHeaderContrast() {
    if (!header) return;
    const probeY = header.offsetHeight / 2;
    const isDark = darkZones.some((el) => {
      const r = el.getBoundingClientRect();
      return r.top <= probeY && r.bottom >= probeY;
    });
    header.classList.toggle('header-dark', isDark);
    header.classList.toggle('header-light', !isDark);
    if (headerLogo) headerLogo.src = isDark ? '/brand/ol_imagotipo-hw.svg' : '/brand/ol_imagotipo-hk.svg';
    if (headerCta) {
      headerCta.classList.toggle('btn-white', isDark);
      headerCta.classList.toggle('btn-black', !isDark);
    }
  }

  let headerTicking = false;
  window.addEventListener('scroll', () => {
    if (!headerTicking) {
      requestAnimationFrame(() => {
        updateHeaderContrast();
        headerTicking = false;
      });
      headerTicking = true;
    }
  }, { passive: true });
  updateHeaderContrast();

  // ── Billing toggle: 2 Plazos / Pago único ──
  const pricingContent = document.getElementById('pricing-content');
  const billingToggle = document.getElementById('billing-toggle');

  billingToggle?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-billing-option]') as HTMLElement | null;
    if (!btn || !pricingContent) return;
    const mode = btn.dataset.billingOption;
    pricingContent.setAttribute('data-billing', mode ?? 'split');
    billingToggle.querySelectorAll('[data-billing-option]').forEach((b) => {
      const isActive = b === btn;
      b.classList.toggle('active', isActive);
      b.setAttribute('aria-selected', String(isActive));
    });
  });

  // ── Form submit ──
  const form  = document.getElementById('hero-contact-form') as HTMLFormElement;
  const btn   = document.getElementById('hero-submit-btn') as HTMLButtonElement;
  const label = document.getElementById('hero-submit-label') as HTMLElement;
  const orbCanvas = document.getElementById('hero-submit-orb') as HTMLCanvasElement;
  const msg   = document.getElementById('hero-status-msg') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !msg || !label || !orbCanvas) return;

    btn.disabled = true;
    label.classList.add('hidden');
    orbCanvas.classList.remove('hidden');
    const orb = mountOrb(orbCanvas, { size: 18, color: '#ffffff', label: 'Enviando tu consulta' });

    const fd = new FormData(form);
    try {
      const res = await fetch('/api/send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fd.get('name'), email: fd.get('email'),
          phone: fd.get('phone'), company: 'Consulta desde Landing',
          message: `[CONSULTA LANDING]\n\n${fd.get('message')}`,
          consent: fd.get('consent') === 'on',
          website_url: fd.get('website_url'),
        })
      });
      const data = await res.json();
      orb.setState('resolving');

      if (res.ok) {
        msg.innerText = '✓ Recibido. Te contactamos en menos de 24h.';
        msg.className = 'text-xs text-center font-sans text-black/60 mt-1 block';
        form.reset();
      } else {
        msg.innerText = `✕ ${data.error || 'No se pudo enviar.'}`;
        msg.className = 'text-xs text-center font-sans text-red-600 mt-1 block';
      }
    } catch {
      orb.setState('resolving');
      msg.innerText = '✕ Error de conexión.';
      msg.className = 'text-xs text-center font-sans text-red-600 mt-1 block';
    } finally {
      setTimeout(() => {
        orb.destroy();
        orbCanvas.classList.add('hidden');
        label.classList.remove('hidden');
        btn.disabled = false;
      }, reduceMotion ? 0 : 700);
    }
  });
</script>
