---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Test Autodiagnóstico Digital | Orbital Leap Studio"
  description="Descubre qué solución web, app o sistema a medida se adapta mejor al momento de tu empresa en solo 6 preguntas."
>
  <main class="relative min-h-screen bg-[#0D0D0D] text-white overflow-x-hidden selection:bg-cyan-500/30">
    
    <style>
      /* ── Brand accent: #14b8a6 (teal-500) ── */
      :root { --accent: #14b8a6; --accent-dim: rgba(20,184,166,0.12); }

      /* Gradient text — used ONLY on the H1 hero headline */
      .brand-gradient-text {
        background: linear-gradient(90deg, #2dd4bf 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .brand-gradient-text-warm {
        background: linear-gradient(90deg, #a855f7 0%, #ec4899 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Progress dots — solid accent */
      .progress-dot-active { background-color: #14b8a6; }

      /* Step counter — solid accent */
      .step-counter { color: #14b8a6; }

      /* Option hover — solid accent badge */
      .quiz-opt:hover .opt-letter {
        background-color: #14b8a6;
        color: #fff;
      }
      .quiz-opt:hover {
        border-color: rgba(20,184,166,0.45);
        background-color: rgba(20,184,166,0.04);
      }

      /* Result badge border */
      .result-badge {
        border: 1px solid rgba(20,184,166,0.35);
        background-color: rgba(20,184,166,0.06);
      }

      /* Input focus — solid accent ring */
      .quiz-input:focus {
        outline: none;
        border-color: #14b8a6;
        box-shadow: 0 0 0 3px rgba(20,184,166,0.12);
      }
    </style>

    <!-- Minimalist Header -->
    <header class="fixed top-0 left-0 w-full z-50 px-6 md:px-12 py-5 bg-[#0D0D0D]/80 backdrop-blur-2xl border-b border-white/[0.06]">
      <nav class="flex justify-between items-center w-full max-w-screen-xl mx-auto">
        <a href="/" class="flex items-center gap-3 group">
          <img src="/brand/ol_imagotipo-hw.svg" alt="Orbital Leap" class="h-7 w-auto group-hover:scale-105 transition-transform" />
        </a>
        
        <span class="font-mono text-xs text-white/50 uppercase tracking-widest">Test Autodiagnóstico</span>
      </nav>
    </header>

    <section class="pt-32 pb-20 md:pt-40 md:pb-28 px-4 sm:px-6 max-w-screen-md mx-auto min-h-screen flex flex-col justify-center">
      
      <div id="quiz-container" class="relative bg-[#141414] border border-white/10 rounded-3xl p-6 sm:p-10 md:p-12 shadow-2xl overflow-hidden backdrop-blur-xl">
        
        <!-- STEP 0: HERO START -->
        <div id="step-0" class="quiz-step flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-white/[0.04] border border-white/10 mb-6">
            <span class="font-mono text-xs uppercase tracking-widest" style="color:#14b8a6;">Test Gratuito · 2 minutos</span>
          </div>

          <h1 class="font-sans text-3xl sm:text-5xl font-medium tracking-tight text-white leading-tight mb-6">
            Descubre qué <span class="italic font-serif font-normal brand-gradient-text">necesita</span> tu negocio
          </h1>

          <p class="font-sans text-brand-light/70 text-base sm:text-lg font-light leading-relaxed max-w-lg mb-8">
            Responde 6 preguntas sencillas y te recomendaremos la solución técnica exacta para el momento actual de tu empresa.
          </p>

          <div class="flex flex-wrap justify-center gap-3 mb-10">
            <span class="font-mono text-xs px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/70">✓ 6 Preguntas</span>
            <span class="font-mono text-xs px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/70">⏱ 2 Minutos</span>
            <span class="font-mono text-xs px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/70">🎯 Recomendación Personalizada</span>
          </div>

          <button 
            type="button" 
            onclick="nextStep(1)"
            class="w-full sm:w-auto px-10 py-4 rounded-xl bg-white text-black font-sans font-medium text-sm uppercase tracking-wider transition-all duration-300 hover:bg-brand-light hover:scale-[1.02] shadow-2xl cursor-pointer"
          >
            Empezar el Test →
          </button>
        </div>

        <!-- STEP 1: MOMENTO ACTUAL -->
        <div id="step-1" class="quiz-step hidden flex-col">
          <div class="flex items-center justify-between mb-6">
            <button type="button" onclick="prevStep(1)" class="font-mono text-xs text-white/60 hover:text-white flex items-center gap-1 transition-colors cursor-pointer">
              <span>←</span> <span>Volver</span>
            </button>

            <div class="flex items-center gap-3">
              <span class="font-mono text-xs step-counter">01 / 06</span>
              <div class="flex gap-1.5">
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
              </div>
            </div>
          </div>

          <h2 class="font-sans text-2xl sm:text-3xl font-medium text-white mb-2">
            ¿En qué momento está <span class="brand-gradient-text">tu empresa</span>?
          </h2>
          <p class="font-sans text-sm text-brand-light/60 font-light mb-8">Cuéntanos cuál es tu situación actual.</p>

          <div class="flex flex-col gap-3">
            <button onclick="selectOption(1, 'A')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">A</span>
              <span class="font-sans text-sm text-white/90">Estoy empezando desde cero, necesito lanzar mi primer producto</span>
            </button>

            <button onclick="selectOption(1, 'B')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">B</span>
              <span class="font-sans text-sm text-white/90">Llevo tiempo operando pero mi web o imagen se ha quedado antigua</span>
            </button>

            <button onclick="selectOption(1, 'C')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">C</span>
              <span class="font-sans text-sm text-white/90">Tengo un negocio en crecimiento y necesito automatizar o crear una app</span>
            </button>

            <button onclick="selectOption(1, 'D')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">D</span>
              <span class="font-sans text-sm text-white/90">Necesito una renovación integral (marca, web y arquitectura técnica)</span>
            </button>
          </div>
        </div>

        <!-- STEP 2: IDENTIDAD VISUAL -->
        <div id="step-2" class="quiz-step hidden flex-col">
          <div class="flex items-center justify-between mb-6">
            <button type="button" onclick="prevStep(2)" class="font-mono text-xs text-white/60 hover:text-white flex items-center gap-1 transition-colors cursor-pointer">
              <span>←</span> <span>Volver</span>
            </button>

            <div class="flex items-center gap-3">
              <span class="font-mono text-xs step-counter">02 / 06</span>
              <div class="flex gap-1.5">
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
              </div>
            </div>
          </div>

          <h2 class="font-sans text-2xl sm:text-3xl font-medium text-white mb-2">
            ¿Tienes diseño de <span class="brand-gradient-text-warm">marca o logotipo</span>?
          </h2>
          <p class="font-sans text-sm text-brand-light/60 font-light mb-8">Colores, tipografía e identidad visual.</p>

          <div class="flex flex-col gap-3">
            <button onclick="selectOption(2, 'A')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">A</span>
              <span class="font-sans text-sm text-white/90">No tengo nada, partimos de una hoja en blanco</span>
            </button>

            <button onclick="selectOption(2, 'B')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">B</span>
              <span class="font-sans text-sm text-white/90">Tengo algo muy básico que improvisé pero no me representa</span>
            </button>

            <button onclick="selectOption(2, 'C')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">C</span>
              <span class="font-sans text-sm text-white/90">Sí, tengo marca sólida y manual de diseño corporativo</span>
            </button>
          </div>
        </div>

        <!-- STEP 3: WEB O APP -->
        <div id="step-3" class="quiz-step hidden flex-col">
          <div class="flex items-center justify-between mb-6">
            <button type="button" onclick="prevStep(3)" class="font-mono text-xs text-white/60 hover:text-white flex items-center gap-1 transition-colors cursor-pointer">
              <span>←</span> <span>Volver</span>
            </button>

            <div class="flex items-center gap-3">
              <span class="font-mono text-xs step-counter">03 / 06</span>
              <div class="flex gap-1.5">
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
              </div>
            </div>
          </div>

          <h2 class="font-sans text-2xl sm:text-3xl font-medium text-white mb-2">
            ¿Dispones de <span class="brand-gradient-text">web o plataforma</span> actualmente?
          </h2>
          <p class="font-sans text-sm text-brand-light/60 font-light mb-8">Tu estado tecnológico actual.</p>

          <div class="flex flex-col gap-3">
            <button onclick="selectOption(3, 'A')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">A</span>
              <span class="font-sans text-sm text-white/90">No tengo página web ni app</span>
            </button>

            <button onclick="selectOption(3, 'B')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">B</span>
              <span class="font-sans text-sm text-white/90">Tengo una web antigua o hecha con plantilla que va lenta</span>
            </button>

            <button onclick="selectOption(3, 'C')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">C</span>
              <span class="font-sans text-sm text-white/90">Tengo web pero necesito una app móvil o panel privado a medida</span>
            </button>
          </div>
        </div>

        <!-- STEP 4: OBJETIVO -->
        <div id="step-4" class="quiz-step hidden flex-col">
          <div class="flex items-center justify-between mb-6">
            <button type="button" onclick="prevStep(4)" class="font-mono text-xs text-white/60 hover:text-white flex items-center gap-1 transition-colors cursor-pointer">
              <span>←</span> <span>Volver</span>
            </button>

            <div class="flex items-center gap-3">
              <span class="font-mono text-xs step-counter">04 / 06</span>
              <div class="flex gap-1.5">
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
              </div>
            </div>
          </div>

          <h2 class="font-sans text-2xl sm:text-3xl font-medium text-white mb-2">
            ¿Cuál es tu <span class="brand-gradient-text-warm">objetivo principal</span>?
          </h2>
          <p class="font-sans text-sm text-brand-light/60 font-light mb-8">Lo que buscas lograr con este proyecto.</p>

          <div class="flex flex-col gap-3">
            <button onclick="selectOption(4, 'A')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">A</span>
              <span class="font-sans text-sm text-white/90">Conseguir clientes y transmitir una imagen profesional</span>
            </button>

            <button onclick="selectOption(4, 'B')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">B</span>
              <span class="font-sans text-sm text-white/90">Lanzar una aplicación móvil o software SaaS al mercado</span>
            </button>

            <button onclick="selectOption(4, 'C')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">C</span>
              <span class="font-sans text-sm text-white/90">Renovar completamente mi tecnología para escalar ventas</span>
            </button>
          </div>
        </div>

        <!-- STEP 5: PRESUPUESTO -->
        <div id="step-5" class="quiz-step hidden flex-col">
          <div class="flex items-center justify-between mb-6">
            <button type="button" onclick="prevStep(5)" class="font-mono text-xs text-white/60 hover:text-white flex items-center gap-1 transition-colors cursor-pointer">
              <span>←</span> <span>Volver</span>
            </button>

            <div class="flex items-center gap-3">
              <span class="font-mono text-xs step-counter">05 / 06</span>
              <div class="flex gap-1.5">
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full bg-white/10"></span>
              </div>
            </div>
          </div>

          <h2 class="font-sans text-2xl sm:text-3xl font-medium text-white mb-2">
            ¿Con qué <span class="brand-gradient-text">rango de presupuesto</span> cuentas?
          </h2>
          <p class="font-sans text-sm text-brand-light/60 font-light mb-8">Orienta la propuesta ideal para tu caso.</p>

          <div class="flex flex-col gap-3">
            <button onclick="selectOption(5, 'A')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">A</span>
              <span class="font-sans text-sm text-white/90">Menos de 3.000 € (Proyecto inicial)</span>
            </button>

            <button onclick="selectOption(5, 'B')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">B</span>
              <span class="font-sans text-sm text-white/90">Entre 3.000 € y 7.500 € (Plataforma profesional)</span>
            </button>

            <button onclick="selectOption(5, 'C')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">C</span>
              <span class="font-sans text-sm text-white/90">Entre 7.500 € y 15.000 € (App móvil o sistema a medida)</span>
            </button>

            <button onclick="selectOption(5, 'D')" class="quiz-opt text-left p-4 rounded-xl bg-white/[0.03] border border-white/10 transition-all flex items-center gap-4 group">
              <span class="opt-letter font-mono text-xs w-7 h-7 rounded-lg bg-white/10 flex items-center justify-center text-white transition-all">D</span>
              <span class="font-sans text-sm text-white/90">Más de 15.000 € (Solución enterprise a gran escala)</span>
            </button>
          </div>
        </div>

        <!-- STEP 6: UNLOCK RESULT -->
        <div id="step-6" class="quiz-step hidden flex-col">
          <div class="flex items-center justify-between mb-6">
            <button type="button" onclick="prevStep(6)" class="font-mono text-xs text-white/60 hover:text-white flex items-center gap-1 transition-colors cursor-pointer">
              <span>←</span> <span>Volver</span>
            </button>

            <div class="flex items-center gap-3">
              <span class="font-mono text-xs step-counter">06 / 06</span>
              <div class="flex gap-1.5">
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
                <span class="w-6 h-1 rounded-full progress-dot-active"></span>
              </div>
            </div>
          </div>

          <h2 class="font-sans text-2xl sm:text-3xl font-medium text-white mb-2">
            ¡Tenemos tu diagnóstico <span class="brand-gradient-text">listo</span>!
          </h2>
          <p class="font-sans text-sm text-brand-light/60 font-light mb-8">
            Introduce tus datos para desbloquear la recomendación personalizada y recibir la propuesta.
          </p>

          <form id="quiz-unlock-form" class="flex flex-col gap-4">
            <div>
              <label class="block font-sans text-xs text-brand-light/60 font-medium mb-1">Nombre o empresa *</label>
              <input type="text" id="quiz-name" required placeholder="Tu nombre / Empresa" class="quiz-input w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-brand-light/40 font-sans text-sm" />
            </div>

            <div>
              <label class="block font-sans text-xs text-brand-light/60 font-medium mb-1">Email de contacto *</label>
              <input type="email" id="quiz-email" required placeholder="hola@tuempresa.com" class="quiz-input w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-brand-light/40 font-sans text-sm" />
            </div>

            <div>
              <label class="block font-sans text-xs text-brand-light/60 font-medium mb-1">Teléfono o WhatsApp *</label>
              <input type="tel" id="quiz-phone" required placeholder="600 000 000" class="quiz-input w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-brand-light/40 font-sans text-sm" />
            </div>

            <div>
              <label class="block font-sans text-xs text-brand-light/60 font-medium mb-1">¿Algo más que quieras contarnos? <span class="text-white/30 font-light">(opcional)</span></label>
              <textarea id="quiz-message" rows="3" placeholder="Cuéntanos más sobre tu proyecto, dudas o plazos que manejas..." class="quiz-input w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-brand-light/30 font-sans text-sm resize-none"></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input type="checkbox" id="test-consent" required
                class="mt-0.5 w-4 h-4 shrink-0 rounded border-white/20 bg-white/5 accent-white cursor-pointer" />
              <label for="test-consent" class="font-sans text-xs text-white/50 font-light leading-relaxed cursor-pointer select-none">
                Acepto el tratamiento de mis datos según la <a href="/privacidad" class="text-white underline underline-offset-2 hover:text-white/70">Política de Privacidad</a> de Orbital Leap.
              </label>
            </div>

            <button type="submit" id="quiz-submit-btn" class="w-full py-4 rounded-xl text-white font-sans font-semibold text-sm uppercase tracking-wider transition-all duration-200 hover:opacity-90 shadow-xl mt-1 cursor-pointer" style="background-color:#14b8a6;">
              Ver Mi Diagnóstico Personalizado →
            </button>

            <p class="text-center font-sans text-[11px] text-brand-light/40 mt-1">
              🔒 100% confidencial. Te enviamos la recomendación técnica por email.
            </p>
          </form>
        </div>

        <!-- STEP RESULT DISPLAY -->
        <div id="step-result" class="quiz-step hidden flex-col text-center">
          <div class="result-badge inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full mb-6 mx-auto">
            <span class="font-mono text-xs uppercase tracking-widest" style="color:#14b8a6;">🎯 Recomendación Personalizada</span>
          </div>

          <h2 id="res-title" class="font-sans text-3xl sm:text-4xl font-medium text-white mb-4">
            Cargando resultado...
          </h2>

          <p id="res-desc" class="font-sans text-brand-light/70 text-base font-light leading-relaxed max-w-lg mb-8 mx-auto">
            Analizando tus respuestas...
          </p>

          <div id="res-deliverables" class="bg-white/[0.03] border border-white/10 rounded-2xl p-6 mb-8 text-left flex flex-col gap-3">
            <!-- Dynamic bullets inserted here -->
          </div>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a id="wa-link" href="#" target="_blank" class="px-8 py-4 rounded-xl bg-emerald-500 text-black font-sans font-medium text-sm uppercase tracking-wider transition-all hover:bg-emerald-400 flex items-center justify-center gap-2">
              💬 Hablar por WhatsApp →
            </a>

            <button onclick="location.reload()" class="px-6 py-4 rounded-xl bg-white/5 border border-white/10 text-white font-sans font-light text-xs uppercase tracking-wider hover:bg-white/10 cursor-pointer">
              ← Repetir Test
            </button>
          </div>
        </div>

      </div>

    </section>

    <Footer />
  </main>
</Layout>

<script>
  let answers: Record<number, string> = {};

  (window as any).nextStep = (step: number) => {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.add('hidden'));
    const target = document.getElementById(`step-${step}`);
    if (target) target.classList.remove('hidden');
  };

  (window as any).prevStep = (currentStep: number) => {
    const prev = currentStep - 1;
    (window as any).nextStep(prev);
  };

  (window as any).selectOption = (questionNum: number, value: string) => {
    answers[questionNum] = value;
    (window as any).nextStep(questionNum + 1);
  };

  const form = document.getElementById('quiz-unlock-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = (document.getElementById('quiz-name') as HTMLInputElement).value;
      const email = (document.getElementById('quiz-email') as HTMLInputElement).value;
      const phone = (document.getElementById('quiz-phone') as HTMLInputElement).value;
      const extraMsg = (document.getElementById('quiz-message') as HTMLTextAreaElement).value;

      let title = 'Plataforma Web a Medida';
      let desc = 'Tu empresa necesita una presencia web sólida, de alta velocidad y orientada a captar clientes con un diseño a medida.';
      let items = ['Diseño UI/UX completo', 'Programación frontend y backend', 'Optimización SEO y velocidad', 'Soporte directo por WhatsApp'];

      if (answers[3] === 'C' || answers[4] === 'B' || answers[5] === 'C' || answers[5] === 'D') {
        title = 'Desarrollo de App Móvil o Plataforma SaaS';
        desc = 'Recomendamos construir una aplicación nativa o sistema a medida con arquitectura escalable.';
        items = ['Desarrollo iOS y Android', 'Base de datos y APIs cloud', 'Código fuente 100% tuyo', 'Despliegues continuos cada semana'];
      } else if (answers[1] === 'A' || answers[5] === 'A') {
        title = 'Pack Lanzamiento Inicial (MVP)';
        desc = 'La mejor opción para arrancar rápido sin presupuestos desorbitados y con la máxima calidad.';
        items = ['Diseño de marca básico', 'Página web rápida y clara', 'Formulario de captación', 'Entrega en tiempo récord'];
      }

      const resTitle = document.getElementById('res-title');
      const resDesc = document.getElementById('res-desc');
      const resDeliv = document.getElementById('res-deliverables');
      const waLink = document.getElementById('wa-link') as HTMLAnchorElement;

      if (resTitle) resTitle.innerText = title;
      if (resDesc) resDesc.innerText = desc;
      if (resDeliv) {
        resDeliv.innerHTML = items.map(it => `
          <div class="flex items-center gap-3 text-sm text-white/90">
            <span style="color:#14b8a6; font-weight:700;">✓</span>
            <span>${it}</span>
          </div>`).join('');
      }

      const waText = encodeURIComponent(`Hola Orbital Leap, he realizado el test autodiagnóstico para mi proyecto ${name}. Mi resultado ha sido: ${title}.`);
      if (waLink) waLink.href = `https://wa.me/34600000000?text=${waText}`;

      (window as any).nextStep('result');

      // Send Lead Email asynchronously
      try {
        await fetch('/api/send-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name,
            email,
            phone,
            company: 'Lead desde Test Autodiagnóstico',
            message: `[RESULTADO TEST AUTODIAGNÓSTICO]\n\nRespuestas: ${JSON.stringify(answers)}\n\nResultado Recomendado: ${title}${extraMsg ? `\n\nMensaje adicional del cliente:\n${extraMsg}` : ''}`
          })
        });
      } catch (err) {
        console.error('Lead send error:', err);
      }
    });
  }
</script>
