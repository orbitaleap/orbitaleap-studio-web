  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { MODE_DRAWS } from 'thinking-orbs';

    gsap.registerPlugin(ScrollTrigger);

    // Cinematic Movie Intro Particle Engine: Cosmic Vortex -> Gravitational Snap -> Orbital Leap Isotipo Emblem
    const canvas = document.getElementById('orbs-canvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d');
      if (ctx) {
        const NUM_PARTICLES = 900;
        let particles: { 
          x: number; 
          y: number; 
          targetX: number; 
          targetY: number; 
          vortexAngle: number;
          vortexRadius: number;
          speed: number;
          radius: number; 
          color: string;
          glowColor: string;
          phase: number;
        }[] = [];

        let logoTargets: { x: number; y: number }[] = [];
        let animationFrameId: number;
        const startTime = performance.now();

        const pathData1 = "M1623.49,0c-398.8,0-724.27,312.9-745.22,706.11h338.05c21.65,0,39.12,17.46,39.12,39.83s-17.46,39.12-39.12,39.12h-338.05c20.96,393.21,346.42,706.79,745.22,706.79s745.94-334.55,745.94-745.91S2035.57,0,1623.49,0Z";
        const pathData2 = "M546.18,706.11h331.76c-19.56-224.88-208.15-400.88-437.92-400.88C196.96,305.22,0,502.17,0,745.94s196.96,440,440.02,440c229.77,0,418.36-176.01,437.92-400.88h-331.76c-22.35,0-39.81-17.46-39.81-39.12s17.46-39.83,39.81-39.83Z";

        function generateLogoTargets(width: number, height: number) {
          const svgNS = "http://www.w3.org/2000/svg";
          const p1 = document.createElementNS(svgNS, "path");
          const p2 = document.createElementNS(svgNS, "path");
          p1.setAttribute("d", pathData1);
          p2.setAttribute("d", pathData2);

          const l1 = p1.getTotalLength();
          const l2 = p2.getTotalLength();
          const totalL = l1 + l2;
          const count1 = Math.round((l1 / totalL) * NUM_PARTICLES);
          const count2 = NUM_PARTICLES - count1;

          const viewBoxW = 2369.43;
          const viewBoxH = 1491.85;
          const logoScale = Math.min(width / viewBoxW, height / viewBoxH) * 0.45;
          const logoOffsetX = (width - viewBoxW * logoScale) / 2;
          const logoOffsetY = (height - viewBoxH * logoScale) / 2;

          logoTargets = [];
          for (let i = 0; i < count1; i++) {
            const pt = p1.getPointAtLength((i / count1) * l1);
            logoTargets.push({ x: pt.x * logoScale + logoOffsetX, y: pt.y * logoScale + logoOffsetY });
          }
          for (let i = 0; i < count2; i++) {
            const pt = p2.getPointAtLength((i / count2) * l2);
            logoTargets.push({ x: pt.x * logoScale + logoOffsetX, y: pt.y * logoScale + logoOffsetY });
          }
        }

        function initParticles() {
          const rect = canvas.getBoundingClientRect();
          const width = rect.width;
          const height = rect.height;
          const cx = width / 2;
          const cy = height / 2;

          generateLogoTargets(width, height);

          particles = [];
          for (let i = 0; i < NUM_PARTICLES; i++) {
            const target = logoTargets[i] || { x: cx, y: cy };
            const vAngle = Math.random() * Math.PI * 2;
            const vRad = Math.random() * Math.max(width, height) * 0.8 + 200;
            
            particles.push({
              x: cx + Math.cos(vAngle) * vRad,
              y: cy + Math.sin(vAngle) * vRad,
              targetX: target.x,
              targetY: target.y,
              vortexAngle: vAngle,
              vortexRadius: vRad,
              speed: Math.random() * 0.02 + 0.01,
              radius: Math.random() * 0.6 + 0.6,
              color: 'rgba(255, 255, 255, 0.65)',
              glowColor: 'rgba(255, 255, 255, 0.2)',
              phase: Math.random() * Math.PI * 2
            });
          }
        }

        function resizeCanvas(isFirst = false) {
          const rect = canvas.getBoundingClientRect();
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          canvas.width = rect.width * dpr;
          canvas.height = rect.height * dpr;

          if (isFirst) {
            // Full init only on first load
            initParticles();
          } else {
            // On subsequent resizes: only recalculate logo targets and update particle targets in-place
            // Never reset particle positions — avoids the disappear glitch
            const rect2 = canvas.getBoundingClientRect();
            generateLogoTargets(rect2.width, rect2.height);
            for (let i = 0; i < particles.length; i++) {
              if (logoTargets[i]) {
                particles[i].targetX = logoTargets[i].x;
                particles[i].targetY = logoTargets[i].y;
              }
            }
          }
        }

        resizeCanvas(true);
        window.addEventListener('resize', () => resizeCanvas(false));

        let mouseX = -1000;
        let mouseY = -1000;
        window.addEventListener('mousemove', (e) => {
          const rect = canvas.getBoundingClientRect();
          mouseX = e.clientX - rect.left;
          mouseY = e.clientY - rect.top;
        });

        const INTRO_DURATION = 8000; // 8 seconds total — no loop

        function animate(now: number) {
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          const width = canvas.width / dpr;
          const height = canvas.height / dpr;
          const cx = width / 2;
          const cy = height / 2;

          // elapsed clamped — never restarts
          const elapsed = Math.min(now - startTime, INTRO_DURATION);

          // Clear canvas each frame
          ctx.save();
          ctx.scale(dpr, dpr);
          ctx.clearRect(0, 0, width, height);

          // PHASE LOGIC (plays once):
          // Phase 1 (0ms    - 2200ms): Cosmic Vortex Spiral inward
          // Phase 2 (2200ms - 3600ms): Gravitational Snap to Logo
          // Phase 3 (3600ms - 8000ms): Logo holds with gentle breathing pulse

          for (let i = 0; i < particles.length; i++) {
            const p = particles[i];

            if (elapsed < 2200) {
              // PHASE 1: Cosmic Vortex Spiral
              p.vortexAngle += p.speed;
              p.vortexRadius *= 0.992;
              p.x = cx + Math.cos(p.vortexAngle) * p.vortexRadius;
              p.y = cy + Math.sin(p.vortexAngle) * p.vortexRadius;
            } else {
              // PHASE 2 & 3: Snap & hold logo — ease in over 1400ms then stay
              const easeProgress = Math.min(1, (elapsed - 2200) / 1400);
              const smoothEase = 1 - Math.pow(1 - easeProgress, 3);

              // Gentle breathing pulse once locked
              const breathe = easeProgress >= 1 ? Math.sin(now * 0.002 + p.phase) * 0.8 : 0;
              const curTargetX = p.targetX + breathe;
              const curTargetY = p.targetY + breathe;

              p.x += (curTargetX - p.x) * 0.08 * smoothEase;
              p.y += (curTargetY - p.y) * 0.08 * smoothEase;

              // Mouse interactive repulsion (Desktop with fine pointer only)
              if (window.matchMedia('(pointer: fine)').matches && window.innerWidth >= 768) {
                const dx = mouseX - p.x;
                const dy = mouseY - p.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 120) {
                  const force = (120 - dist) / 120;
                  p.x -= (dx / dist) * force * 18;
                  p.y -= (dy / dist) * force * 18;
                }
              }
            }

            // Draw Particle Dot
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
            ctx.fillStyle = p.color;
            ctx.shadowBlur = 0;
            ctx.fill();
          }

          ctx.restore();
          if (isHeroInView) {
            animationFrameId = requestAnimationFrame(animate);
          } else {
            animationFrameId = 0;
          }
        }

        let isHeroInView = true;
        const heroEl = document.getElementById('hero-section');
        if (heroEl && 'IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              isHeroInView = entry.isIntersecting;
              if (isHeroInView && !animationFrameId) {
                animationFrameId = requestAnimationFrame(animate);
              }
            });
          }, { threshold: 0.05 });
          observer.observe(heroEl);
        } else {
          animationFrameId = requestAnimationFrame(animate);
        }
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      const tl = gsap.timeline({ defaults: { ease: "expo.out" } });
      
      tl.fromTo(".hero-line", 
        { yPercent: 100 }, 
        { yPercent: 0, duration: 2, stagger: 0.15 }
      )
      .fromTo(".hero-bottom", 
        { y: 30, opacity: 0 }, 
        { y: 0, opacity: 1, duration: 2 }, 
        "-=1.5"
      );

      // Cursor rotating ring (Hardware Accelerated & Responsive)
      const heroSection = document.querySelector('#hero-section') as HTMLElement;
      const cursorRing = document.getElementById('cursor-ring') as HTMLElement;
      if (cursorRing && heroSection && window.matchMedia('(pointer: fine)').matches) {
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        let curX = mouseX, curY = mouseY;
        let rotation = 0;
        let isHovered = false;
        let animationFrameId: number;

        heroSection.addEventListener('mouseenter', () => {
          isHovered = true;
          cursorRing.style.opacity = '1';
          cursorRing.style.transition = 'opacity 0.3s ease';
          if (!animationFrameId) spinRing();
        });

        heroSection.addEventListener('mouseleave', () => {
          isHovered = false;
          cursorRing.style.opacity = '0';
        });

        window.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
        }, { passive: true });

        function spinRing() {
          if (!isHovered) {
            animationFrameId = 0;
            return;
          }
          // Responsive lerp (0.35) for instant, lag-free cursor tracking
          curX += (mouseX - curX) * 0.35;
          curY += (mouseY - curY) * 0.35;
          rotation += 0.4;
          
          cursorRing.style.transform = `translate3d(${curX}px, ${curY}px, 0) rotate(${rotation}deg)`;
          animationFrameId = requestAnimationFrame(spinRing);
        }
      }

      // Hero-to-Services Cinematic Scroll Parallax (Desktop Only via matchMedia)
      const heroMM = gsap.matchMedia();
      heroMM.add("(min-width: 768px)", () => {
        gsap.to(".hero-parallax-content", {
          yPercent: -50,
          opacity: 0,
          scale: 0.9,
          ease: "none",
          scrollTrigger: {
            trigger: "#servicios",
            start: "top bottom",
            end: "top top",
            scrub: true
          }
        });

        gsap.to(".hero-parallax-bg", {
          yPercent: -25,
          opacity: 0.2,
          ease: "none",
          scrollTrigger: {
            trigger: "#servicios",
            start: "top bottom",
            end: "top top",
            scrub: true
          }
        });
      });


      // Progressive Letter-by-Letter Blur Reveal Function
      function splitTextToChars(element) {
        if (element.children.length > 0) return null; // Safe guard
        const text = element.textContent.trim();
        if (!text) return null;
        
        element.innerHTML = '';
        const chars = [];
        
        // Wrap words to preserve line breaking
        const words = text.split(' ');
        words.forEach((word, wordIndex) => {
          const wordSpan = document.createElement('span');
          wordSpan.style.display = 'inline-block';
          wordSpan.style.whiteSpace = 'nowrap';
          
          [...word].forEach(char => {
            const charSpan = document.createElement('span');
            charSpan.innerText = char;
            charSpan.style.opacity = '0';
            charSpan.style.filter = 'blur(12px)';
            charSpan.style.display = 'inline-block';
            charSpan.style.willChange = 'opacity, filter';
            wordSpan.appendChild(charSpan);
            chars.push(charSpan);
          });
          
          element.appendChild(wordSpan);
          
          if (wordIndex < words.length - 1) {
            const spaceSpan = document.createElement('span');
            spaceSpan.innerHTML = '&nbsp;';
            element.appendChild(spaceSpan);
          }
        });
        
        return chars;
      }

      // Fade out scroll indicator on scroll
      gsap.to('#scroll-indicator', {
        opacity: 0,
        scrollTrigger: {
          trigger: "body",
          start: "top top",
          end: "top -150px",
          scrub: true
        }
      });

      // Remove character blur JS logic to keep typography 100% crisp

      // Generic container fade-up (without text blur, just layout movement)
      gsap.utils.toArray('.fade-up').forEach((el: any) => {
        gsap.fromTo(el, 
          { y: 40, opacity: 0 },
          {
            scrollTrigger: {
              trigger: el,
              start: "top 85%",
              toggleActions: "play none none reverse"
            },
            y: 0,
            opacity: 1,
            duration: 1.5,
            ease: "expo.out"
          }
        );
      });

      // Dual-Container Interactive Services Pinned Parallax Scroll Sequence
      const tabBtns = document.querySelectorAll('.service-tab-btn');
      const contentPanels = document.querySelectorAll('.service-content-panel');
      let currentActiveIndex = 0;

      function switchServiceTab(targetIndex: number) {
        if (currentActiveIndex === targetIndex && contentPanels[targetIndex] && contentPanels[targetIndex].classList.contains('opacity-100')) return;
        currentActiveIndex = targetIndex;

        tabBtns.forEach((btn, idx) => {
          const borderWrapper = btn.querySelector('.border-beam-wrapper');
          if (idx === targetIndex) {
            btn.classList.add('border-white/20', 'active-service-tab');
            if (borderWrapper) {
              borderWrapper.classList.remove('opacity-0');
              borderWrapper.classList.add('opacity-100');
            }
          } else {
            btn.classList.remove('border-white/20', 'active-service-tab');
            if (borderWrapper) {
              borderWrapper.classList.remove('opacity-100');
              borderWrapper.classList.add('opacity-0');
            }
          }
        });

        contentPanels.forEach((panel, idx) => {
          if (idx === targetIndex) {
            panel.classList.remove('opacity-0', 'pointer-events-none', 'scale-[0.98]');
            panel.classList.add('opacity-100', 'pointer-events-auto', 'scale-100');
          } else {
            panel.classList.remove('opacity-100', 'pointer-events-auto', 'scale-100');
            panel.classList.add('opacity-0', 'pointer-events-none', 'scale-[0.98]');
          }
        });
      }

      tabBtns.forEach((btn, index) => {
        btn.addEventListener('mouseenter', () => switchServiceTab(index));
        btn.addEventListener('click', () => switchServiceTab(index));
      });

      // Mobile Services Accordion Toggle Logic
      const mobileItems = document.querySelectorAll('.mobile-service-item');
      const mobileToggles = document.querySelectorAll('.mobile-service-toggle');
      const mobileBodies = document.querySelectorAll('.mobile-service-body');
      const mobileIcons = document.querySelectorAll('.mobile-service-icon');

      mobileToggles.forEach((btn, idx) => {
        btn.addEventListener('click', () => {
          mobileItems.forEach((item, i) => {
            const body = mobileBodies[i];
            const icon = mobileIcons[i];
            const borderBeam = item.querySelector('.border-beam-wrapper');

            if (i === idx) {
              const isOpen = !body.classList.contains('max-h-0');
              if (isOpen) {
                body.classList.add('max-h-0', 'pb-0');
                body.classList.remove('max-h-[600px]', 'pb-6');
                item.classList.remove('active-mobile-service', 'border-white/20');
                item.classList.add('border-white/12');
                if (borderBeam) {
                  borderBeam.classList.remove('opacity-100');
                  borderBeam.classList.add('opacity-0');
                }
                if (icon) icon.textContent = '+';
              } else {
                body.classList.remove('max-h-0', 'pb-0');
                body.classList.add('max-h-[600px]', 'pb-6');
                item.classList.add('active-mobile-service', 'border-white/20');
                item.classList.remove('border-white/12');
                if (borderBeam) {
                  borderBeam.classList.remove('opacity-0');
                  borderBeam.classList.add('opacity-100');
                }
                if (icon) icon.textContent = '−';
              }
            } else {
              body.classList.add('max-h-0', 'pb-0');
              body.classList.remove('max-h-[600px]', 'pb-6');
              item.classList.remove('active-mobile-service', 'border-white/20');
              item.classList.add('border-white/12');
              if (borderBeam) {
                borderBeam.classList.remove('opacity-100');
                borderBeam.classList.add('opacity-0');
              }
              if (icon) icon.textContent = '+';
            }
          });
        });
      });



      // Horizontal Scroll Methodology Section (Desktop Only via matchMedia)
      const mm = gsap.matchMedia();
      const methodologyPin = document.querySelector('#methodology-pin');
      const methodologyScroll = document.querySelector('#methodology-scroll');
      const methodologyProgress = document.querySelector('#methodology-progress');
      
      if (methodologyPin && methodologyScroll) {
        mm.add("(min-width: 768px)", () => {
          gsap.set(methodologyScroll, { willChange: "transform" });

          const methodologyTl = gsap.timeline({
            scrollTrigger: {
              trigger: methodologyPin,
              pin: true,
              scrub: 1,
              end: () => `+=${methodologyScroll.scrollWidth - window.innerWidth}`
            }
          });

          methodologyTl.to(methodologyScroll, {
            x: () => -(methodologyScroll.scrollWidth - window.innerWidth),
            ease: "none",
            force3D: true
          }, 0);

          if (methodologyProgress) {
            methodologyTl.to(methodologyProgress, {
              scaleX: 1,
              ease: "none"
            }, 0);
          }
        });
      }

      // Native Parallax Footer Animation sequence
      const footer = document.querySelector('#contacto');
      const footerCtaText = document.querySelector('#footer-cta-text');
      const footerCtaBtn = document.querySelector('#footer-cta-btn');

      if (footer && footerCtaText && footerCtaBtn) {
        // Split text into characters with white-to-blue gradient tinting (matching DevOps reference)
        const text = footerCtaText.innerText;
        footerCtaText.innerHTML = '';
        const totalChars = text.length;

        // Signature service gradient (from Integraciones DevOps): Pure White (#FFFFFF) -> Mint Teal (#2DD4BF) -> Electric Blue (#3B82F6)
        function getGradientColor(t: number) {
          if (t <= 0.5) {
            const localT = t / 0.5;
            const r = Math.round(255 + (45 - 255) * localT);
            const g = Math.round(255 + (212 - 255) * localT);
            const b = Math.round(255 + (191 - 255) * localT);
            return `rgb(${r}, ${g}, ${b})`;
          } else {
            const localT = (t - 0.5) / 0.5;
            const r = Math.round(45 + (59 - 45) * localT);
            const g = Math.round(212 + (130 - 212) * localT);
            const b = Math.round(191 + (246 - 191) * localT);
            return `rgb(${r}, ${g}, ${b})`;
          }
        }

        const targetColors: string[] = [];

        [...text].forEach((char, idx) => {
          const span = document.createElement('span');
          span.innerText = char === ' ' ? '\u00A0' : char;
          span.style.opacity = '0.2'; // Muted initial opacity
          span.style.color = 'rgba(255, 255, 255, 0.2)'; // Muted initial color
          span.style.display = 'inline-block';
          span.style.willChange = 'color, opacity';
          footerCtaText.appendChild(span);

          targetColors.push(getGradientColor(idx / Math.max(1, totalChars - 1)));
        });

        const charSpans = footerCtaText.querySelectorAll('span');

        const footerTl = gsap.timeline({
          scrollTrigger: {
            trigger: footerCtaText,
            start: "top 85%", 
            end: "bottom 45%", 
            scrub: 0.8
          }
        });

        // 1. Scale container text smoothly from 0.75 to 1
        footerTl.fromTo(footerCtaText,
          { scale: 0.75, y: 40 },
          { scale: 1, y: 0, duration: 1, ease: "power2.out" },
          0
        );

        // 2. Fill color & opacity letter-by-letter as you scroll
        charSpans.forEach((span, idx) => {
          const color = targetColors[idx];
          footerTl.to(span, {
            color: color,
            opacity: 1,
            duration: 0.15,
            ease: "none"
          }, 0.05 + idx * 0.04);
        });

        // 3. Fade in the email CTA button elegantly as text locks in
        footerTl.fromTo(footerCtaBtn,
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.3, ease: "power2.out" },
          0.7
        );
      }

      // Lightweight Accordions for Methodology Rows
      const accHeaders = document.querySelectorAll('.methodology-accordion-header');
      accHeaders.forEach(header => {
        header.addEventListener('click', (e) => {
          e.stopPropagation();
          const content = header.nextElementSibling as HTMLElement;
          const icon = header.querySelector('.methodology-accordion-icon');
          if (!content || !icon) return;

          const isOpen = content.style.height !== '0px' && content.style.height !== '';

          if (isOpen) {
            content.style.height = '0px';
            icon.textContent = '+';
          } else {
            content.style.height = content.scrollHeight + 'px';
            icon.textContent = '-';
          }
        });
      });

    });
  </script>
</Layout>
