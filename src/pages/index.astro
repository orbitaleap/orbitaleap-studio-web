---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

const services = [
  { 
    id: '01', 
    slug: 'branding-e-identidad', 
    title: 'Branding e identidad', 
    desc: 'Damos vida a la imagen de tu proyecto. Creamos marcas, logotipos y guías de estilo que transmiten profesionalismo y destacan en tu sector desde el primer momento.', 
    colorFrom: '#a855f7', 
    colorTo: '#ec4899',
    impact: 'Identidad sólida & valor percibido',
    deliverables: ['Identidad visual & Isotipo', 'Manual de marca', 'Paleta cromática & Tipografía', 'Assets gráficos para producción']
  },
  { 
    id: '02', 
    slug: 'experiencia-ui-ux', 
    title: 'Experiencia UI/UX', 
    desc: 'Interfaces intuitivas y fáciles de usar. Diseñamos pantallas y flujos donde tus usuarios navegan de forma sencilla y encuentran lo que buscan sin complicaciones.', 
    colorFrom: '#f43f5e', 
    colorTo: '#fb923c',
    impact: 'Navegación intuitiva & alta conversión',
    deliverables: ['Diseño de páginas & pantallas', 'Prototipos visuales navegables', 'Arquitectura de información', 'Adaptación móvil & responsive']
  },
  { 
    id: '03', 
    slug: 'desarrollo-app-web', 
    title: 'Desarrollo Web & Apps', 
    desc: 'Páginas web, tiendas online y aplicaciones móviles. Programamos sitios rápidos, modernos y adaptados a móviles, creados a medida para crecer con tu proyecto.', 
    colorFrom: '#e879f9', 
    colorTo: '#6366f1',
    impact: 'Velocidad de carga & experiencia impecable',
    deliverables: ['Webs corporativas & Landing pages', 'Tiendas online & E-commerce', 'Aplicaciones móviles iOS & Android', 'SEO & Optimización de velocidad']
  },
  { 
    id: '04', 
    slug: 'consultoria-estrategica', 
    title: 'Consultoría & Asesoramiento', 
    desc: 'Te guiamos en la toma de decisiones. Analizamos tu idea o tu sistema actual para recomendarte las mejores herramientas, optimizar costes y evitar problemas técnicos.', 
    colorFrom: '#ffaa40', 
    colorTo: '#9c40ff',
    impact: 'Decisiones claras & ahorro de costes',
    deliverables: ['Auditoría de tu web o sistema', 'Recomendación de tecnología', 'Plan de desarrollo & etapas', 'Asesoramiento técnico cercano']
  },
  { 
    id: '05', 
    slug: 'desarrollo-cloud-native', 
    title: 'Servidores & Infraestructura', 
    desc: 'Bases de datos y servidores preparados para responder siempre. Nos aseguramos de que tu plataforma funcione de manera fluida y segura sin importar el volumen de visitas.', 
    colorFrom: '#38bdf8', 
    colorTo: '#818cf8',
    impact: 'Máxima estabilidad & seguridad 24/7',
    deliverables: ['Bases de datos rápidas & seguras', 'Servidores en la nube', 'Integración de pasarelas de pago', 'APIs & Conexión de servicios']
  },
  { 
    id: '06', 
    slug: 'integraciones-devops', 
    title: 'Mantenimiento & Soporte', 
    desc: 'Tu tecnología siempre al día. Automatizamos actualizaciones y mantenemos tu web o app protegida para que tú solo te preocupes por hacer crecer tu negocio.', 
    colorFrom: '#2dd4bf', 
    colorTo: '#3b82f6',
    impact: 'Cero preocupaciones & soporte continuo',
    deliverables: ['Actualizaciones automatizadas', 'Backups & Copias de seguridad', 'Monitorización de estabilidad', 'Soporte técnico directo']
  }
];

const team = [
  { role: 'CEO & Founder', name: 'Juan Carlos González' },
  { role: 'Designer & Co-Founder', name: 'Manuel Gomes' },
  { role: 'Jefe de Marketing', name: 'Ivo Torres' },
];

const methodology = [
  {
    stage: '01',
    title: 'Entendemos tu proyecto',
    desc: "Analizamos tus objetivos y necesidades reales antes de ponernos a diseñar o programar.",
    how: [
      "Reunión inicial para definir objetivos, público objetivo y alcance.",
      "Planificación transparente de fases, plazos y presupuesto sin sorpresas."
    ],
    expect: "Hoja de ruta clara con objetivos bien definidos y calendario de entregas."
  },
  {
    stage: '02',
    title: 'Diseñamos la experiencia',
    desc: "Creamos prototipos visuales interactivos para que veas exactamente cómo quedará tu web o app.",
    how: [
      "Diseño visual de pantallas, estructura de contenidos y paleta de colores.",
      "Prototipos navegables para que puedas probar el diseño antes de construirlo."
    ],
    expect: "Bocetos visuales completos y prototipo interactivo aprobado por ti."
  },
  {
    stage: '03',
    title: 'Desarrollamos a medida',
    desc: "Programamos tu solución con código rápido y seguro, realizando pruebas en todos los dispositivos.",
    how: [
      "Programación limpia optimizada para buscadores (SEO) y teléfonos móviles.",
      "Pruebas de velocidad, usabilidad y seguridad antes del lanzamiento."
    ],
    expect: "Tu web o aplicación lista en un entorno de pruebas privado para tu revisión."
  },
  {
    stage: '04',
    title: 'Lanzamiento & Acompañamiento',
    desc: "Publicamos tu proyecto, lo dejamos 100% operativo y seguimos a tu lado para lo que necesites.",
    how: [
      "Paso a producción, configuración de dominio y correo corporativo.",
      "Soporte técnico cercano y acompañamiento para futuras mejoras."
    ],
    expect: "Producto publicado y funcionado con soporte técnico continuo."
  }
];

const projects = [
  { 
    id: '01',
    title: 'Nova Platform', 
    category: 'POINT OF SALE / SAAS PLATFORM',
    desc: 'TPV inteligente y arquitectura de baja latencia para el sector de la hostelería de nueva generación.', 
    image: '/images/portfolio/mars.jpg',
    tags: ['Next.js', 'PostgreSQL', 'UI/UX', 'Cloud Native'],
    year: '2025'
  },
  { 
    id: '02',
    title: 'Horizon', 
    category: 'HOSPITALITY / BRANDING & WEB',
    desc: 'Transformación digital, plataforma de reservas y sistema visual completo para el sector hospitality.', 
    image: '/images/portfolio/moon.jpg',
    tags: ['Design System', 'Astro', 'UI/UX', 'SEO'],
    year: '2024'
  },
  { 
    id: '03',
    title: 'BIG BURGER MAD', 
    category: 'RETAIL / BRANDING & RETAIL',
    desc: 'Branding con carácter, identidad visual disruptiva y arquitectura digital para franquicia retail.', 
    image: '/images/portfolio/mountains.jpg',
    tags: ['Identidad Visual', 'E-commerce', 'Mobile UX'],
    year: '2024'
  },
  { 
    id: '04',
    title: '180º Roasters', 
    category: 'SPECIALTY COFFEE / E-COMMERCE',
    desc: 'Experiencia e-commerce minimalista y narrativa de marca para el mercado de specialty coffee.', 
    image: '/images/portfolio/saltflat.jpg',
    tags: ['Shopify Headless', 'Branding', 'Web Performance'],
    year: '2024'
  }
];
---

<Layout title="Orbital Leap - Plataformas escalables y consultoría">
  <Navbar />

  <main class="relative w-full bg-brand-bg">
    
    <section id="hero-section" class="relative md:sticky md:top-0 min-h-[85vh] md:h-screen w-full flex flex-col justify-center pt-24 pb-12 px-6 md:px-12 xl:px-24 overflow-hidden bg-[#111111] z-0">
      
      <div class="hero-parallax-bg absolute inset-0 w-full h-full z-0 overflow-hidden bg-[#111111]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.09) 1.2px, transparent 0), linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 36px 36px, 36px 36px, 36px 36px;">
        <canvas id="orbs-canvas" class="absolute inset-0 w-full h-full pointer-events-none opacity-70 z-0"></canvas>
      </div>
      
      <div class="hero-parallax-content relative z-10 w-full max-w-screen-2xl mx-auto will-change-transform">
        <h1 class="font-sans text-[2.75rem] sm:text-6xl md:text-7xl lg:text-[5.5rem] font-medium tracking-tighter leading-[0.98] mb-6 text-brand-light">
          <div class="overflow-hidden py-1"><div class="hero-line">Diseño & desarrollo</div></div>
          <div class="overflow-hidden py-1"><div class="hero-line">digital a medida.</div></div>
        </h1>
        
        <p class="text-lg sm:text-xl md:text-2xl text-brand-light/70 font-sans max-w-2xl font-light leading-relaxed">
          Diseñamos y desarrollamos productos digitales a medida. Desde la web de tu proyecto hasta aplicaciones empresariales complejas, con atención al detalle y un rendimiento impecable.
        </p>
      </div>
      
      <div id="cursor-ring" class="hidden md:block fixed z-50 pointer-events-none opacity-0 will-change-transform" style="top:0;left:0;width:110px;height:110px;margin-left:-55px;margin-top:-55px;">
        <svg viewBox="0 0 110 110" width="110" height="110" style="overflow:visible">
          <defs>
            <path id="ring-path" d="M 55,55 m -38,0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0" />
          </defs>
          <text font-family="'Inter', sans-serif" font-size="8.5" font-weight="300" fill="rgba(255,255,255,0.75)" letter-spacing="3.5">
            <textPath href="#ring-path">· DESPLAZA PARA EXPLORAR · DESPLAZA PARA EXPLORAR ·</textPath>
          </text>
        </svg>
      </div>
    </section>

    <section id="servicios" class="relative z-10 py-16 md:py-24 lg:py-32 px-6 md:px-12 xl:px-24 bg-[#111111]">
      <div class="max-w-screen-2xl mx-auto w-full">
        <div class="mb-12 md:mb-16 section-header">
          <h2 class="font-sans text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-medium text-brand-light tracking-tighter leading-none mb-6">
            Especialización & servicios.
          </h2>
          <div class="w-full h-px bg-white/[0.1]"></div>
        </div>

        <!-- MOBILE ACCORDION SYSTEM (< lg) -->
        <div class="flex flex-col gap-4 lg:hidden w-full" id="services-mobile-accordion">
          {services.map((service, index) => (
            <div 
              class={`mobile-service-item relative border rounded-2xl bg-[#161616] overflow-hidden transition-all duration-500 ${index === 0 ? 'active-mobile-service border-white/20' : 'border-white/12'}`}
              style={`--color-from: ${service.colorFrom}; --color-to: ${service.colorTo};`}
            >
              <!-- Animated Border Beam SVG Overlay -->
              <div class={`border-beam-wrapper pointer-events-none absolute inset-0 z-20 transition-opacity duration-500 overflow-hidden ${index === 0 ? 'opacity-100' : 'opacity-0'}`}>
                <svg class="w-full h-full" fill="none">
                  <rect width="100%" height="100%" rx="16" pathLength="1000" stroke={`url(#mobile-tab-gradient-${index})`} stroke-width="2.5" class="magic-border-beam-svg" />
                  <defs>
                    <linearGradient id={`mobile-tab-gradient-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" stop-color={service.colorFrom} stop-opacity="1" />
                      <stop offset="40%" stop-color={service.colorTo} stop-opacity="0.9" />
                      <stop offset="70%" stop-color="#00FFF0" stop-opacity="0.7" />
                      <stop offset="100%" stop-color={service.colorFrom} stop-opacity="0" />
                    </linearGradient>
                  </defs>
                </svg>
              </div>

              <!-- Ambient Color Glow Backdrop -->
              <div 
                class="absolute -top-16 -right-16 w-64 h-64 rounded-full blur-3xl opacity-15 pointer-events-none z-0"
                style={`background: radial-gradient(circle, ${service.colorFrom} 0%, transparent 70%);`}
              ></div>

              <button 
                type="button" 
                data-mobile-index={index}
                class="mobile-service-toggle relative z-10 w-full p-5 sm:p-6 flex items-center justify-between text-left cursor-pointer group"
              >
                <h3 class="service-title-text font-sans text-xl sm:text-2xl font-medium text-white/50 transition-all duration-500">
                  {service.title}
                </h3>
                <span class="mobile-service-icon w-8 h-8 rounded-full border border-white/15 flex items-center justify-center text-white/60 font-mono text-sm transition-transform duration-300 shrink-0 ml-3">
                  {index === 0 ? '−' : '+'}
                </span>
              </button>

              <div class={`mobile-service-body relative z-10 transition-all duration-300 ease-out overflow-hidden px-5 sm:px-6 ${index === 0 ? 'max-h-[600px] pb-6' : 'max-h-0 pb-0'}`}>
                <div class="w-full h-px bg-white/10 mb-4"></div>
                <p class="font-sans text-brand-light/80 font-light text-base leading-relaxed mb-5">
                  {service.desc}
                </p>
                <div>
                  <span class="font-sans text-[11px] text-brand-light/40 uppercase tracking-widest block mb-2.5 font-medium">ENTREGABLES CONCRETOS</span>
                  <div class="flex flex-wrap gap-2">
                    {service.deliverables.map(del => (
                      <span class="font-sans text-xs px-3.5 py-1.5 rounded-full bg-white/5 border border-white/10 text-brand-light/80 font-light">
                        {del}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- DESKTOP INTERACTIVE SPLIT GRID (>= lg) -->
        <div class="hidden lg:grid grid-cols-12 gap-8 lg:gap-12 w-full items-start" id="services-interactive">
          <div class="lg:col-span-5 flex flex-col items-start gap-3 sm:gap-4">
            {services.map((service, index) => (
              <button
                type="button"
                data-service-index={index}
                class={`service-tab-btn text-left group relative inline-flex items-center justify-between px-6 py-3.5 rounded-xl border border-transparent transition-all duration-500 cursor-pointer overflow-hidden ${index === 0 ? 'active-service-tab border-white/20' : ''}`}
                style={`--color-from: ${service.colorFrom}; --color-to: ${service.colorTo};`}
              >
                <div class={`border-beam-wrapper pointer-events-none absolute inset-0 z-20 transition-opacity duration-500 overflow-hidden ${index === 0 ? 'opacity-100' : 'opacity-0 group-hover:opacity-100'}`}>
                  <svg class="w-full h-full" fill="none">
                    <rect width="100%" height="100%" rx="12" pathLength="1000" stroke={`url(#tab-gradient-${index})`} stroke-width="2.5" class="magic-border-beam-svg" />
                    <defs>
                      <linearGradient id={`tab-gradient-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color={service.colorFrom} stop-opacity="1" />
                        <stop offset="40%" stop-color={service.colorTo} stop-opacity="0.9" />
                        <stop offset="70%" stop-color="#00FFF0" stop-opacity="0.7" />
                        <stop offset="100%" stop-color={service.colorFrom} stop-opacity="0" />
                      </linearGradient>
                    </defs>
                  </svg>
                </div>

                <h3 class="service-title-text relative z-10 font-sans text-2xl sm:text-3xl md:text-4xl lg:text-[2.6rem] font-medium tracking-tight whitespace-nowrap text-white/30 transition-all duration-500">
                  {service.title}
                </h3>
              </button>
            ))}
          </div>

          <div class="lg:col-span-7 sticky top-28 w-full min-h-[380px] relative">
            {services.map((service, index) => (
              <div 
                id={`service-content-${index}`} 
                class={`service-content-panel absolute inset-0 w-full h-fit bg-[#161616] border border-white/12 rounded-2xl p-7 md:p-9 transition-all duration-300 ease-out overflow-hidden shadow-2xl backdrop-blur-xl ${index === 0 ? 'opacity-100 pointer-events-auto scale-100' : 'opacity-0 pointer-events-none scale-[0.98]'}`}
                style={`--color-from: ${service.colorFrom}; --color-to: ${service.colorTo};`}
              >
                <div 
                  class="absolute inset-0 w-full h-full pointer-events-none opacity-20 z-0"
                  style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 200 200\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noiseFilter\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.85\' numOctaves=\'3\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noiseFilter)\'/%3E%3C/svg%3E');"
                ></div>

                <div 
                  class="absolute -top-20 -right-20 w-80 h-80 rounded-full blur-3xl opacity-10 pointer-events-none"
                  style={`background: radial-gradient(circle, ${service.colorFrom} 0%, transparent 70%);`}
                ></div>

                <div class="relative z-10 flex flex-col gap-5">
                  <h3 class="font-sans text-2xl md:text-3xl lg:text-4xl font-medium tracking-tight text-white whitespace-nowrap overflow-hidden text-ellipsis">
                    {service.title}
                  </h3>

                  <div class="w-full h-px bg-white/10"></div>

                  <p class="font-sans text-brand-light/80 font-light text-base md:text-lg leading-relaxed">
                    {service.desc}
                  </p>
                  <div>
                    <span class="font-sans text-xs text-brand-light/40 uppercase tracking-widest block mb-3 font-medium">ENTREGABLES CONCRETOS</span>
                    <div class="flex flex-wrap gap-2">
                      {service.deliverables.map(del => (
                        <span class="font-sans text-xs px-3.5 py-1.5 rounded-full bg-white/5 border border-white/10 text-brand-light/80 font-light">
                          {del}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Methodology Section -->
    <section id="metodologia" data-theme="light" class="relative bg-[#F9F9F9] text-black w-full border-t border-black/[0.05]">
      
      <!-- MOBILE VERTICAL COLUMN LAYOUT (< md) -->
      <div class="block md:hidden px-6 py-16 w-full">
        <div class="flex items-center gap-4 mb-10">
          <div class="relative w-14 h-14 shrink-0">
            <svg viewBox="0 0 100 100" class="w-full h-full animate-[spin_15s_linear_infinite]">
              <path id="circlePathMobile" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="transparent" />
              <text class="text-[13px] font-sans font-medium uppercase fill-black/60">
                <textPath href="#circlePathMobile" startOffset="0" textLength="232.4" lengthAdjust="spacing">
                  NUESTRA METODOLOGÍA • NUESTRA METODOLOGÍA • 
                </textPath>
              </text>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <img src="/brand/ol_isotipo-k.svg" alt="" aria-hidden="true" class="w-6 h-6 opacity-80" />
            </div>
          </div>
          <h2 class="font-sans text-3xl font-medium tracking-tighter leading-tight text-black">Nuestra metodología.</h2>
        </div>

        <div class="flex flex-col gap-10 w-full">
          {methodology.map((stage) => (
            <div class="flex flex-col w-full border-b border-black/10 pb-8">
              <span class="font-sans text-black/40 text-xs font-medium tracking-[0.2em] uppercase mb-3 block">Fase {stage.stage}</span>
              <h3 class="font-sans text-2xl font-medium tracking-tight mb-3 text-black">{stage.title}</h3>
              <p class="font-sans text-black/60 font-light text-base leading-relaxed mb-5">{stage.desc}</p>

              <div class="flex flex-col w-full">
                <div class="border-t border-black/10">
                  <button type="button" class="methodology-accordion-header w-full py-4 flex justify-between items-center text-left cursor-pointer group">
                    <span class="font-sans text-xs tracking-[0.15em] uppercase text-black/60 font-medium">¿Cómo lo hacemos?</span>
                    <span class="methodology-accordion-icon font-mono text-sm text-black/40">+</span>
                  </button>
                  <div class="methodology-accordion-content h-0 overflow-hidden transition-all duration-300 ease-out">
                    <div class="pb-4 pt-1">
                      <ul class="flex flex-col gap-2.5">
                        {stage.how.map((item, index) => (
                          <li class="font-sans text-black/80 font-light text-sm leading-relaxed flex">
                            <span class="text-black/30 font-mono text-xs mr-2.5 mt-0.5">{index + 1}.</span> 
                            <span>{item}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </div>

                <div class="border-t border-black/10 border-b border-black/10">
                  <button type="button" class="methodology-accordion-header w-full py-4 flex justify-between items-center text-left cursor-pointer group">
                    <span class="font-sans text-xs tracking-[0.15em] uppercase text-black/60 font-medium">¿Qué recibirás?</span>
                    <span class="methodology-accordion-icon font-mono text-sm text-black/40">+</span>
                  </button>
                  <div class="methodology-accordion-content h-0 overflow-hidden transition-all duration-300 ease-out">
                    <div class="pb-4 pt-1">
                      <p class="font-sans text-black/80 font-light text-sm leading-relaxed">{stage.expect}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- DESKTOP PINNED HORIZONTAL SCROLL LAYOUT (>= md) -->
      <div id="methodology-pin" class="hidden md:flex h-screen w-full flex-col relative overflow-hidden">
        <div class="absolute left-0 top-0 w-full p-6 md:px-12 xl:px-24 pt-16 md:pt-24 z-20 pointer-events-none">
          <div class="flex items-center gap-6 md:gap-8 w-full max-w-screen-2xl mx-auto">
            <div class="relative w-20 h-20 md:w-28 md:h-28 shrink-0">
              <svg viewBox="0 0 100 100" class="w-full h-full animate-[spin_15s_linear_infinite]">
                <path id="circlePath" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="transparent" />
                <text class="text-[13px] font-sans font-medium uppercase fill-black/60">
                  <textPath href="#circlePath" startOffset="0" textLength="232.4" lengthAdjust="spacing">
                    NUESTRA METODOLOGÍA • NUESTRA METODOLOGÍA • 
                  </textPath>
                </text>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center">
                <img src="/brand/ol_isotipo-k.svg" alt="" aria-hidden="true" class="w-8 h-8 opacity-80" />
              </div>
            </div>
            <div>
              <h2 class="font-sans text-4xl md:text-5xl xl:text-6xl font-normal tracking-tighter leading-[0.9] text-black">Nuestra metodología.</h2>
            </div>
          </div>
        </div>

        <div class="w-full h-full flex items-end pb-32">
          <div id="methodology-scroll" class="flex flex-row items-stretch h-[65vh] px-6 md:px-[6vw] xl:px-[12vw] w-max gap-8 md:gap-20">
          {methodology.map((stage, i) => (
            <div class={`flex flex-col w-[85vw] md:w-[35vw] shrink-0 group relative z-10 ${i % 2 === 0 ? 'mt-auto mb-8' : 'mb-auto mt-12'}`}>
              <div class="mb-10">
                <span class="font-sans text-black/40 text-xs font-medium tracking-[0.2em] uppercase mb-6 block">Fase {stage.stage}</span>
                <h3 class="font-sans text-4xl md:text-5xl tracking-tight mb-6 text-black">{stage.title}</h3>
                <p class="font-sans text-black/60 font-light text-base md:text-lg leading-relaxed max-w-md">{stage.desc}</p>
              </div>

              <div class="flex flex-col w-full max-w-xl mt-4">
                <div class="border-t border-black/10">
                  <button type="button" class="methodology-accordion-header w-full py-5 flex justify-between items-center text-left cursor-pointer group pointer-events-auto">
