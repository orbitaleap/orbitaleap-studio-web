---
import '../styles/global.css';
import ScrollProgress from '../components/ScrollProgress.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = "Orbital Leap - Software Development & Consulting", lang = "es" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&family=Product+Sans:wght@400;500;700&family=Roboto+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="bg-brand-bg text-brand-light min-h-screen flex flex-col relative">
    <ScrollProgress />
    
    <!-- Progressive Top Edge Blur (Single High-Performance GPU Layer) -->
    <div class="fixed top-0 inset-x-0 h-20 pointer-events-none z-40 backdrop-blur-md [mask-image:linear-gradient(to_bottom,black_0%,transparent_100%)]"></div>



    <slot />

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Removed Lenis temporarily to isolate the source of the scroll lag.
    </script>
  </body>
</html>
