---
import { Icon } from 'astro-icon/components';

interface Props {
  /** Drops the full-bleed "¿Listo para dar el salto?" CTA and the in-page
   * section nav. Use on pages that already end with their own closing CTA
   * (e.g. /launch), so visitors aren't shown two calls to action back to back. */
  compact?: boolean;
  /** Light color scheme (off-white bg, black text) instead of the default
   * dark one — for pages that end on a light section and don't want the
   * footer flipping back to dark right after it. */
  light?: boolean;
}
const { compact = false, light = false } = Astro.props;
const currentYear = new Date().getFullYear();

const bg = light ? 'bg-[#F7F7F5]' : 'bg-[#111111]';
const ink = light ? 'text-black' : 'text-white';
const border = light ? 'border-black/10' : 'border-white/10';
const logo = light ? '/brand/ol_imagotipo-hk.svg' : '/brand/ol_imagotipo-hw.svg';
const dotPattern = light
  ? 'radial-gradient(circle at 1px 1px, rgba(0,0,0,0.07) 1.2px, transparent 0), linear-gradient(to right, rgba(0,0,0,0.02) 1px, transparent 1px), linear-gradient(to bottom, rgba(0,0,0,0.02) 1px, transparent 1px)'
  : 'radial-gradient(circle at 1px 1px, rgba(255,255,255,0.09) 1.2px, transparent 0), linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px)';
---
<footer class={`relative ${bg} ${ink} ${compact ? 'pt-12 pb-8 px-6 md:px-12 xl:px-20' : 'pt-24 pb-12 px-6 md:px-12 xl:px-24'} border-t ${border} overflow-hidden`} id="contacto" style={`background-image: ${dotPattern}; background-size: 36px 36px, 36px 36px, 36px 36px;`}>

  {!compact && (
    <div class={`w-full flex flex-col items-center justify-center text-center relative z-10 py-16 md:py-24 border-b ${border}`}>
      <h2 id="footer-cta-text" class={`font-sans text-4xl sm:text-6xl md:text-7xl lg:text-8xl leading-[0.95] font-medium tracking-tighter ${ink} mb-10 cursor-default max-w-5xl mx-auto`}>
        ¿Listo para dar el salto?
      </h2>

      <a href="mailto:hello@orbitaleap.com" id="footer-cta-btn" class="group relative inline-flex items-center gap-4 bg-white border border-white rounded-xl px-9 py-4 md:px-11 md:py-5 text-base md:text-lg font-medium overflow-hidden transition-all duration-[400ms]">
        <span class="relative z-10 text-white mix-blend-difference">hello@orbitaleap.com</span>
        <Icon name="ph:arrow-up-right-bold" class="w-5 h-5 text-white relative z-10 mix-blend-difference group-hover:rotate-45 transition-transform duration-[400ms] ease-[cubic-bezier(0.22,1,0.36,1)]" />
        <div class="absolute inset-0 bg-[#111111] translate-y-full group-hover:translate-y-0 transition-transform duration-[400ms] ease-[cubic-bezier(0.22,1,0.36,1)]"></div>
      </a>
    </div>
  )}

  <div class={`mx-auto ${compact ? 'max-w-screen-xl py-10 gap-8' : 'max-w-screen-2xl py-16 gap-12'} grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 border-b ${border}`}>

    <div class="lg:col-span-5 flex flex-col items-start gap-5">
      <a href="/" class="opacity-90 hover:opacity-100 transition-opacity">
        <img src={logo} alt="Orbital Leap Logo" class="h-8 w-auto" />
      </a>
      <p class={`font-sans ${light ? 'text-black/60' : 'text-white/60'} font-light text-sm md:text-base leading-relaxed max-w-sm`}>
        Estudio de diseño y desarrollo digital. Creamos páginas web, plataformas y aplicaciones a medida para particulares, marcas y empresas.
      </p>
    </div>

    <div class="lg:col-span-2 flex flex-col gap-4">
      <span class={`font-sans text-xs ${light ? 'text-black/40' : 'text-white/40'} uppercase tracking-widest font-medium mt-2`}>Navegación</span>
      <ul class={`flex flex-col gap-3 font-sans text-sm ${light ? 'text-black/70' : 'text-white/70'}`}>
        <li><a href="/#servicios" class={`${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>Servicios</a></li>
        <li><a href="/#metodologia" class={`${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>Metodología</a></li>
        <li><a href="/#portfolio" class={`${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>Portafolio</a></li>
        <li><a href="#contacto" class={`${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>Contacto</a></li>
      </ul>
    </div>

    <div class="lg:col-span-3 flex flex-col gap-4">
      <span class={`font-sans text-xs ${light ? 'text-black/40' : 'text-white/40'} uppercase tracking-widest font-medium`}>Contacto & Legal</span>
      <ul class={`flex flex-col gap-3 font-sans text-sm ${light ? 'text-black/70' : 'text-white/70'}`}>
        <li><a href="mailto:hello@orbitaleap.com" class={`${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>hello@orbitaleap.com</a></li>
        <li><a href="tel:+34623947598" class={`${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>+34 623 94 75 98</a></li>
        <li><a href="/privacidad" class={`${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>Política de Privacidad</a></li>
        <li><a href="/cookies" class={`${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>Política de Cookies</a></li>
      </ul>
    </div>

    <div class="lg:col-span-2 flex flex-col gap-4">
      <span class={`font-sans text-xs ${light ? 'text-black/40' : 'text-white/40'} uppercase tracking-widest font-medium`}>Redes Sociales</span>
      <ul class={`flex flex-col gap-3 font-sans text-sm ${light ? 'text-black/70' : 'text-white/70'}`}>
        <li><a href="https://www.linkedin.com/company/orbital-leap/" target="_blank" rel="noopener noreferrer" class={`inline-flex items-center gap-1 ${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>LinkedIn <Icon name="ph:arrow-up-right-bold" class="w-3 h-3" /></a></li>
        <li><a href="https://www.instagram.com/orbitaleap/" target="_blank" rel="noopener noreferrer" class={`inline-flex items-center gap-1 ${light ? 'hover:text-black' : 'hover:text-white'} transition-colors`}>Instagram <Icon name="ph:arrow-up-right-bold" class="w-3 h-3" /></a></li>
      </ul>
    </div>

  </div>

  <div class={`mx-auto ${compact ? 'max-w-screen-xl pt-6' : 'max-w-screen-2xl pt-8'} flex flex-col sm:flex-row justify-between items-center gap-4`}>
    <p class={`font-sans ${light ? 'text-black/40' : 'text-white/40'} text-xs font-light`}>
      &copy; {currentYear} Orbital Leap Technologies, S.L. Todos los derechos reservados.
    </p>
  </div>

</footer>
